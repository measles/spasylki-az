<!doctype html>
<html lang="be">
  <head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-5BSTJH63H8"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-5BSTJH63H8');
    </script>
    <!-- Google tag (gtag.js) -->
    <meta charset="UTF-8" />
    <title>Спасылкі Андрэя З.</title>
    <!-- Add Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
  </head>
  <body class="bg-light">
    <header class="p-3 page-header text-primary-emphasis bg-primary-subtle border border-primary-subtle rounded-3">
      <h1>Мая калекцыя беларускіх спасылак. <small>Андрэй З.</small></h1>
    </header>
    <main class="container p-3">
      <div class="accordion" id="links">
        {% for section in links %}
        <!-- {{ section.description }} -->
        <div class="accordion-item">
          <h2  class="accordion-header">
              <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse{{ section.name }}" aria-expanded="false" aria-controls="collapse{{ section.name }}">
                {{ section.description }}
              </button>
          </h2>
          <div id="collapse{{ section.name }}" class="accordion-collapse collapse" data-bs-parent="#links">
              <div class="accordion-body">
                <div class="list-group">
                    {% for url, description in section.links %}<a href="{{ url }}">{{ url }} </a>{{ description }} 
                    {% endfor %}
                </div>
              </div>
          </div>
        </div>
        <!-- {{ section.description }} -->
        {% endfor %}
      </div>
    </main>
  </body>
</html>